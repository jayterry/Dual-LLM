## SMS Guard / Agentproject — 環境變數範本（可安全推上 Git）
## 使用方式：
## - 複製成 .env 後再填入（.env 已在 .gitignore，不會被推上去）
## - 或在 PowerShell 用 $env:NAME="value" 設定

## Ollama 設定
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

## 向量 embedding 後端（目前只支援 ollama）
RAG_EMBEDDING_BACKEND=ollama

## API 安全（可選）
## 若設定了 token，手機/客戶端必須帶 Header:
## Authorization: Bearer <token>
# AGENT_API_TOKEN=change-me

## Toxic DB（可選）
## 指到 toxic_db.json 的路徑（如果你選擇把 toxic_db.json 放進 repo，就用相對路徑）
# TOXIC_DB_PATH=toxic_db.json

## User profile DB（可選）
## 預設會用專案目錄下的 user_profile_db.json（此檔已被 .gitignore 排除）
# USER_PROFILE_DB_PATH=user_profile_db.json
# USER_BURST_N=8

## Toxic similarity / risk fusion（可選進階參數）
# TOXIC_COS_TAU=0.55
# TOXIC_COS_GAMMA=2.0
# FUSED_RISK_W_LLM=0.75
# FUSED_RISK_W_TOX=0.25
# FUSED_RISK_BIAS=0.0

## Chat 加速（可選）
## 同一則 text+source 在 TTL 秒內重複問，重用審查 JSON 只跑對答 LLM
CHAT_REUSE_REPORT_TTL_SEC=900

## Logging（可選）
LOG_LEVEL=INFO
# LOG_FILE=server.log
